# Environment
ENV=development
DEBUG=True

# API
API_V1_PREFIX=/api/v1
API_TITLE=GrabGo ML Service
API_VERSION=1.0.0
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY=your-api-key-for-backend-integration

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=True

# PostgreSQL (from your existing GrabGo backend)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=grabgo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql+asyncpg://postgres:your-postgres-password@localhost:5432/grabgo

# MongoDB (from your existing GrabGo backend)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=grabgo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Model Settings
MODEL_DIR=./ml_models
MODEL_UPDATE_INTERVAL=3600  # seconds
RECOMMENDATION_CACHE_TTL=300  # seconds
PREDICTION_CACHE_TTL=60  # seconds

# Feature Flags
ENABLE_RECOMMENDATIONS=True
ENABLE_FRAUD_DETECTION=True
ENABLE_DEMAND_FORECASTING=True
ENABLE_SENTIMENT_ANALYSIS=True

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=9090

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=True

# ML Model Hyperparameters
RECOMMENDATION_TOP_N=10
RECOMMENDATION_MIN_SCORE=0.3
FRAUD_THRESHOLD=0.7
CHURN_THRESHOLD=0.6

# External Services (if needed)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
WEATHER_API_KEY=your-weather-api-key

# Node.js Backend Integration
BACKEND_URL=http://localhost:5000
BACKEND_API_KEY=your-backend-api-key
