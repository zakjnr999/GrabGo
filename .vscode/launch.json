{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Customer App (Debug)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/grab_go_customer",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define-from-file=${workspaceFolder}/.dart_defines.json"
      ]
    },
    {
      "name": "Customer App (Profile)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/grab_go_customer",
      "flutterMode": "profile",
      "toolArgs": [
        "--dart-define-from-file=${workspaceFolder}/.dart_defines.json"
      ]
    },
    {
      "name": "Customer App (Release)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/grab_go_customer",
      "flutterMode": "release",
      "toolArgs": [
        "--dart-define-from-file=${workspaceFolder}/.dart_defines.json"
      ]
    },
    {
      "name": "Customer App - Android",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/grab_go_customer",
      "flutterMode": "debug",
      "args": ["-d", "android"],
      "toolArgs": [
        "--dart-define-from-file=${workspaceFolder}/.dart_defines.json"
      ]
    },
    {
      "name": "Rider App (Debug)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/grab_go_rider",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define-from-file=${workspaceFolder}/.dart_defines.json"
      ]
    },
    {
      "name": "Admin App (Debug)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/grab_go_admin",
      "flutterMode": "debug",
      "args": ["-d", "chrome"],
      "toolArgs": [
        "--dart-define-from-file=${workspaceFolder}/.dart_defines.json"
      ]
    }
  ]
