{
  "name": "grabgo-backend",
  "version": "1.0.0",
  "description": "Backend API for GrabGo food delivery platform",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "pretest": "prisma generate",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/init-db.js",
    "add-foods": "node scripts/add-sample-foods.js",
    "add-statuses": "node scripts/add-sample-statuses.js",
    "setup-restaurants": "node scripts/setup-restaurants-and-foods.js",
    "create-dummy-data": "node scripts/tmp_rovodev_create_dummy_food_data.js",
    "pickup:flow": "node scripts/pickup_vendor_flow.js",
    "test-mtn-momo": "node scripts/test-mtn-momo.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:status": "jest tests/status.test.js",
    "test:cache": "jest tests/cache.test.js",
    "test:routes": "jest tests/status.routes.test.js",
    "test:tracking": "jest tests/tracking.routes.test.js",
    "docs:build": "npx @redocly/cli build-docs docs/openapi.yaml -o docs/index.html",
    "docs:lint": "npx @redocly/cli lint docs/openapi.yaml",
    "docs:serve": "npx serve docs -l 8080",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "migrate:postgres": "node scripts/migrate-to-postgres.js"
  },
  "keywords": [
    "food-delivery",
    "api",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "blurhash": "^2.0.5",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "geolib": "^3.3.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "node-geocoder": "^4.4.1",
    "nodemailer": "^7.0.10",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.10.4"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "baseline-browser-mapping": "^2.10.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
