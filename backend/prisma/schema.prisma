// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum UserRole {
  customer
  restaurant
  rider
  admin
}

enum OrderType {
  food
  grocery
  pharmacy
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  picked_up
  on_the_way
  delivered
  cancelled
}

enum PaymentMethod {
  cash
  card
  mobile_money
  mtn_momo
  online
}

enum PaymentProvider {
  mtn_momo
  vodafone_cash
  airtel_money
  tigo_cash
  stripe
  paystack
}

enum PaymentStatus {
  pending
  processing
  paid
  successful
  failed
  cancelled
  expired
  refunded
}

enum VehicleType {
  motorcycle
  bicycle
  car
  scooter
}

enum IdType {
  national_id
  passport
  drivers_license
}

enum MobileMoneyProvider {
  mtn
  vodafone
  airtel
  tigo
}

enum VerificationStatus {
  pending
  under_review
  approved
  rejected
}

enum EntityStatus {
  pending
  approved
  rejected
  suspended
}

enum CartType {
  food
  grocery
  pharmacy
}

enum ItemType {
  Food
  GroceryItem
  PharmacyItem
}



enum PromoType {
  percentage
  fixed
  free_delivery
}



enum ReengagementLevel {
  none
  two_weeks
  one_month
  two_months
}



enum Currency {
  GHS
  USD
  EUR
}

enum UnitType {
  kg
  lbs
  piece
  pack
  dozen
  liter
  ml
  gram
}

enum Platform {
  android
  ios
  web
}



enum ReferralStatus {
  pending
  pending_order
  completed
  expired
}

// ==================== MODELS ====================

model Referral {
  id                 String         @id @default(cuid())
  referrerId         String
  refereeId          String
  referralCode       String
  status             ReferralStatus @default(pending)
  rewardAmount           Float          @default(0)
  refereeDiscountAmount  Float          @default(0)
  expiresAt              DateTime?
  refereeOrderId         String?
  referrerCreditId       String?
  refereeCreditId        String?
  referrerCreditedAt     DateTime?
  completedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrer User @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referee  User @relation("RefereeReferrals", fields: [refereeId], references: [id])

  @@unique([referrerId, refereeId])
  @@index([referrerId])
  @@index([refereeId])
  @@map("referrals")
}

model ReferralCode {
  id                 String @id @default(cuid())
  userId             String @unique
  code               String @unique
  usageCount         Int    @default(0)
  completedReferrals Int    @default(0)
  totalEarned        Float  @default(0)
  maxUses            Int?
  rewardPerUse       Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("referral_codes")
}

enum CreditSource {
  referral_earned
  referral_received
  promotion
  refund
  bonus
}

model UserCredit {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        CreditSource
  description String?
  isUsed      Boolean   @default(false)
  isActive    Boolean   @default(true)
  usedAt      DateTime?
  expiresAt   DateTime?
  referralId  String?
  orderId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isUsed])
  @@map("user_credits")
}



// ==================== MODELS ====================

model User {
  id                            String    @id @default(cuid())
  username                      String    @unique
  email                         String    @unique
  password                      String?
  phone                         String?
  isPhoneVerified               Boolean   @default(false)
  isEmailVerified               Boolean   @default(false)
  emailVerificationToken        String?
  emailVerificationTokenExpires DateTime?
  emailVerificationOTP          String?
  emailVerificationOTPExpires   DateTime?
  phoneVerificationOTP          String?
  phoneVerificationOTPExpires   DateTime?
  dateOfBirth                   String?
  profilePicture                String?
  googleId                      String?
  isAdmin                       Boolean   @default(false)
  role                          UserRole  @default(customer)
  isActive                      Boolean   @default(true)
  lastSeenAt                    DateTime?
  lastOrderDate                 DateTime?
  weekStartDate                 DateTime?
  
  // Permissions
  canManageUsers    Boolean @default(false)
  canManageProducts Boolean @default(false)
  canManageOrders   Boolean @default(false)
  canManageContent  Boolean @default(false)

  // Meal-time nudge tracking
  lastMealNudgeAt            DateTime?
  mealNudgesThisWeek         Int               @default(0)
  lastFavoritesNudgeAt       DateTime?
  favoritesNudgesThisWeek    Int               @default(0)
  lastReorderSuggestionAt    DateTime?
  reorderSuggestionsThisWeek Int               @default(0)
  lastReengagementNudgeAt    DateTime?
  reengagementLevel          ReengagementLevel @default(none)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  fcmTokens               UserFcmToken[]
  notificationSettings    UserNotificationSettings?
  mealTimePreferences     UserMealTimePreferences?
  favoriteRestaurants     UserFavoriteRestaurant[]
  favoriteStores          UserFavoriteStore[]
  favoritePharmacies      UserFavoritePharmacy[]
  favoriteFoods           UserFavoriteFood[]
  favoriteGroceryItems    UserFavoriteGroceryItem[]
  favoriteGrabMartItems   UserFavoriteGrabMartItem[]
  orders                  Order[]                   @relation("CustomerOrders")
  riderOrders             Order[]                   @relation("RiderOrders")
  carts                   Cart[]
  payments                Payment[]
  rider                   Rider?
  riderWallet             RiderWallet?
  transactions            Transaction[]
  referralsSent           Referral[]                @relation("ReferrerReferrals")
  referralsReceived       Referral[]                @relation("RefereeReferrals")
  referralCode            ReferralCode?
  userCredits             UserCredit[]
  promoCodesCreated       PromoCode[]               @relation("PromoCodeCreator")
  targetedPromoCodes      PromoCodeTargetedUser[]
  scheduledNotifications  ScheduledNotification[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model UserFcmToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  deviceId  String?
  platform  Platform @default(android)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@map("user_fcm_tokens")
}

model UserNotificationSettings {
  id                    String  @id @default(cuid())
  userId                String  @unique
  chatMessages          Boolean @default(true)
  orderUpdates          Boolean @default(true)
  promoNotifications    Boolean @default(true)
  commentReplies        Boolean @default(true)
  commentReactions      Boolean @default(true)
  referralUpdates       Boolean @default(true)
  paymentUpdates        Boolean @default(true)
  deliveryUpdates       Boolean @default(true)
  systemUpdates         Boolean @default(true)
  cartReminders         Boolean @default(true)
  favoritesReminders    Boolean @default(true)
  reorderSuggestions    Boolean @default(true)
  reengagementReminders Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_settings")
}

model UserMealTimePreferences {
  id         String  @id @default(cuid())
  userId     String  @unique
  enabled    Boolean @default(true)
  breakfast  Boolean @default(true)
  lunch      Boolean @default(true)
  dinner     Boolean @default(true)
  maxPerWeek Int     @default(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_meal_time_preferences")
}

model UserFavoriteRestaurant {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String
  addedAt      DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@map("user_favorite_restaurants")
}

model UserFavoriteStore {
  id      String   @id @default(cuid())
  userId  String
  storeId String
  addedAt DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  store GroceryStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@map("user_favorite_stores")
}

model UserFavoritePharmacy {
  id         String   @id @default(cuid())
  userId     String
  pharmacyId String
  addedAt    DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pharmacy PharmacyStore @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([userId, pharmacyId])
  @@map("user_favorite_pharmacies")
}

model UserFavoriteFood {
  id      String   @id @default(cuid())
  userId  String
  foodId  String
  addedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([userId, foodId])
  @@map("user_favorite_foods")
}

model UserFavoriteGroceryItem {
  id            String   @id @default(cuid())
  userId        String
  groceryItemId String
  addedAt       DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  groceryItem GroceryItem @relation(fields: [groceryItemId], references: [id], onDelete: Cascade)

  @@unique([userId, groceryItemId])
  @@map("user_favorite_grocery_items")
}

model UserFavoriteGrabMartItem {
  id             String   @id @default(cuid())
  userId         String
  grabMartItemId String
  addedAt        DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  grabMartItem GrabMartItem @relation(fields: [grabMartItemId], references: [id], onDelete: Cascade)

  @@unique([userId, grabMartItemId])
  @@map("user_favorite_grabmart_items")
}

// ==================== RESTAURANT & FOOD ====================

model Restaurant {
  id                     String       @id @default(cuid())
  restaurantName         String
  email                  String       @unique
  phone                  String
  ownerFullName          String
  ownerContactNumber     String
  businessIdNumber       String       @unique
  password               String
  logo                   String?
  businessIdPhoto        String?
  ownerPhoto             String?
  foodType               String?
  description            String?
  averageDeliveryTime    Int          @default(30)
  averagePreparationTime Int          @default(15)
  deliveryFee            Float        @default(0)
  minOrder               Float        @default(0)
  paymentMethods         String[]     @default([])
  bannerImages           String[]     @default([])
  status                 EntityStatus @default(pending)
  rating                 Float        @default(0)
  ratingCount            Int          @default(0)
  isOpen                 Boolean      @default(true)

  // Location (PostGIS)
  longitude Float
  latitude  Float
  address   String
  city      String
  area      String

  // Socials
  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  websiteUrl   String?
  
  // Verification & Priority
  isVerified            Boolean   @default(false)
  verifiedAt            DateTime?
  priorityScore         Float     @default(0)
  orderAcceptanceRate   Float     @default(100)
  orderCancellationRate Float     @default(0)
  featured              Boolean   @default(false)
  featuredUntil         DateTime?
  
  // Metadata & Features
  features              String[]  @default([])
  tags                  String[]  @default([])
  whatsappNumber        String?
  timezone              String    @default("Africa/Accra")
  utcOffset             Int       @default(0)
  
  // Stats
  totalOrders          Int       @default(0)
  totalCancelledOrders Int       @default(0)
  totalRevenue         Float     @default(0)
  monthlyRevenue       Float     @default(0)
  last30DaysRevenue    Float     @default(0) 
  averageOrderValue    Float     @default(0)
  monthlyOrders        Int       @default(0)
  
  // Operational & Legacy
  ratingSum            Float     @default(0)
  totalReviews         Int       @default(0)
  isAcceptingOrders    Boolean   @default(true)
  isGrabGoExclusive    Boolean   @default(false)
  isGrabGoExclusiveUntil DateTime?
  vendorType           String    @default("restaurant")
  isDeleted            Boolean   @default(false)
  lastOnlineAt         DateTime  @default(now())
  
  parentVendorId       String?
  parentVendor         Restaurant? @relation("RestaurantHierarchy", fields: [parentVendorId], references: [id])
  subVendors           Restaurant[] @relation("RestaurantHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  openingHours RestaurantHours[]
  foods        Food[]
  categories   Category[]
  orders       Order[]
  favoritedBy  UserFavoriteRestaurant[]

  @@index([status])
  @@index([city])
  @@index([rating])
  @@map("restaurants")
}

model RestaurantHours {
  id           String  @id @default(cuid())
  restaurantId String
  dayOfWeek    Int // 0 = Sunday, 1 = Monday, etc.
  openTime     String  @default("09:00")
  closeTime    String  @default("21:00")
  isClosed     Boolean @default(false)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
  @@map("restaurant_hours")
}

model Category {
  id           String  @id @default(cuid())
  name         String
  description  String?
  emoji        String?
  image        String?
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)
  restaurantId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  foods      Food[]

  @@index([restaurantId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("categories")
}

model Food {
  id                 String    @id @default(cuid())
  name               String
  description        String?
  price              Float
  foodImage          String?
  categoryId         String
  restaurantId       String
  isAvailable        Boolean   @default(true)
  ingredients        String[]  @default([])
  rating             Float     @default(0)
  totalReviews       Int       @default(0)
  discountPercentage Int       @default(0)
  discountEndDate    DateTime?
  orderCount         Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category       Category           @relation(fields: [categoryId], references: [id])
  restaurant     Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  cartItems      CartItem[]
  favoritedBy    UserFavoriteFood[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([orderCount])
  @@map("foods")
}

// ==================== GROCERY STORE ====================

model GroceryStore {
  id          String       @id @default(cuid())
  storeName   String
  logo        String
  description String?
  phone       String
  email       String       @unique
  password    String
  status      EntityStatus @default(pending)
  rating      Float        @default(0)
  ratingCount Int          @default(0)
  isOpen      Boolean      @default(true)
  deliveryFee Float        @default(0)
  minOrder    Float        @default(0)

  // Location
  longitude Float
  latitude  Float
  address   String
  city      String
  area      String

  // Socials
  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  websiteUrl   String?
  
  storeType            String?   // Added based on Mongoose schema

  // Verification & Priority
  isVerified            Boolean   @default(false)
  verifiedAt            DateTime?
  priorityScore         Float     @default(0)
  orderAcceptanceRate   Float     @default(100)
  orderCancellationRate Float     @default(0)
  featured              Boolean   @default(false)
  featuredUntil         DateTime?
  
  // Metadata & Features
  features              String[]  @default([])
  tags                  String[]  @default([])
  whatsappNumber        String?
  timezone              String    @default("Africa/Accra")
  utcOffset             Int       @default(0)
  
  // Stats
  totalOrders          Int       @default(0)
  totalCancelledOrders Int       @default(0)
  totalRevenue         Float     @default(0)
  monthlyRevenue       Float     @default(0)
  last30DaysRevenue    Float     @default(0) 
  averageOrderValue    Float     @default(0)
  monthlyOrders        Int       @default(0)
  
  // Operational & Legacy
  ratingSum            Float     @default(0)
  totalReviews         Int       @default(0)
  isAcceptingOrders    Boolean   @default(true)
  isGrabGoExclusive    Boolean   @default(false)
  isGrabGoExclusiveUntil DateTime?
  vendorType           String    @default("grocery")
  isDeleted            Boolean   @default(false)
  lastOnlineAt         DateTime  @default(now())
  
  parentVendorId       String?
  parentVendor         GroceryStore? @relation("GroceryStoreHierarchy", fields: [parentVendorId], references: [id])
  subVendors           GroceryStore[] @relation("GroceryStoreHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  openingHours GroceryStoreHours[]
  categories   GroceryCategory[]
  items        GroceryItem[]
  orders       Order[]             @relation("GroceryStoreOrders")
  favoritedBy  UserFavoriteStore[]

  @@index([status])
  @@index([city])
  @@map("grocery_stores")
}

model GroceryStoreHours {
  id        String  @id @default(cuid())
  storeId   String
  dayOfWeek Int
  openTime  String  @default("09:00")
  closeTime String  @default("21:00")
  isClosed  Boolean @default(false)

  store GroceryStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, dayOfWeek])
  @@map("grocery_store_hours")
}

model GroceryCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  emoji       String?
  description String?
  image       String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  storeId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store GroceryStore? @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items GroceryItem[]

  @@index([storeId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("grocery_categories")
}

model GroceryItem {
  id                 String    @id @default(cuid())
  name               String
  description        String?
  image              String
  price              Float
  unit               UnitType
  categoryId         String?
  storeId            String
  brand              String?
  stock              Int       @default(0)
  isAvailable        Boolean   @default(true)
  discountPercentage Int       @default(0)
  discountEndDate    DateTime?
  tags               String[]  @default([])
  rating             Float     @default(0)
  reviewCount        Int       @default(0)
  orderCount         Int       @default(0)

  // Nutrition info
  calories Int @default(0)
  protein  Int @default(0)
  carbs    Int @default(0)
  fat      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   GroceryCategory? @relation(fields: [categoryId], references: [id])
  store      GroceryStore     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]
  favoritedBy UserFavoriteGroceryItem[]

  @@index([storeId])
  @@index([categoryId])
  @@index([orderCount])
  @@map("grocery_items")
}

// ==================== PHARMACY STORE ====================

model PharmacyStore {
  id             String       @id @default(cuid())
  storeName      String
  logo           String
  description    String?
  phone          String
  email          String       @unique
  password       String
  status         EntityStatus @default(pending)
  rating         Float        @default(0)
  ratingCount    Int          @default(0)
  isOpen         Boolean      @default(true)
  deliveryFee    Float        @default(0)
  minOrder       Float        @default(0)
  licenseNumber  String?      @unique
  pharmacistName String?

  // Pharmacy Specific
  emergencyService     Boolean  @default(false)
  prescriptionRequired Boolean  @default(false)
  operatingHoursString String?  // For legacy "24/7" support
  bannerImages         String[] @default([])

  // Location
  longitude Float
  latitude  Float
  address   String
  city      String
  area      String
  
  // Pharmacy Specific
  pharmacistLicense    String?
  insuranceAccepted    String[] @default([])

  // Verification & Priority
  isVerified            Boolean   @default(false)
  verifiedAt            DateTime?
  priorityScore         Float     @default(0)
  orderAcceptanceRate   Float     @default(100)
  orderCancellationRate Float     @default(0)
  featured              Boolean   @default(false)
  featuredUntil         DateTime?
  
  // Metadata & Features
  features              String[]  @default([])
  tags                  String[]  @default([])
  whatsappNumber        String?
  timezone              String    @default("Africa/Accra")
  utcOffset             Int       @default(0)
  
  // Stats
  totalOrders          Int       @default(0)
  totalCancelledOrders Int       @default(0)
  totalRevenue         Float     @default(0)
  monthlyRevenue       Float     @default(0)
  last30DaysRevenue    Float     @default(0) 
  averageOrderValue    Float     @default(0)
  monthlyOrders        Int       @default(0)
  
  // Operational & Legacy
  ratingSum            Float     @default(0)
  totalReviews         Int       @default(0)
  isAcceptingOrders    Boolean   @default(true)
  isGrabGoExclusive    Boolean   @default(false)
  isGrabGoExclusiveUntil DateTime?
  vendorType           String    @default("pharmacy")
  isDeleted            Boolean   @default(false)
  lastOnlineAt         DateTime  @default(now())
  
  parentVendorId       String?
  parentVendor         PharmacyStore? @relation("PharmacyStoreHierarchy", fields: [parentVendorId], references: [id])
  subVendors           PharmacyStore[] @relation("PharmacyStoreHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  openingHours PharmacyStoreHours[]
  categories   PharmacyCategory[]
  items        PharmacyItem[]
  orders       Order[]                @relation("PharmacyStoreOrders")
  favoritedBy  UserFavoritePharmacy[]

  @@index([status])
  @@index([city])
  @@map("pharmacy_stores")
}

model PharmacyStoreHours {
  id        String  @id @default(cuid())
  storeId   String
  dayOfWeek Int
  openTime  String  @default("09:00")
  closeTime String  @default("21:00")
  isClosed  Boolean @default(false)

  store PharmacyStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, dayOfWeek])
  @@map("pharmacy_store_hours")
}

model PharmacyCategory {
  id          String  @id @default(cuid())
  name        String
  description String?
  emoji       String?
  image       String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  storeId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store PharmacyStore? @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items PharmacyItem[]

  @@index([storeId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("pharmacy_categories")
}

model PharmacyItem {
  id                   String    @id @default(cuid())
  name                 String
  description          String?
  image                String
  price                Float
  unit                 String?
  categoryId           String?
  storeId              String
  brand                String?
  stock                Int       @default(0)
  isAvailable          Boolean   @default(true)
  requiresPrescription Boolean   @default(false)
  discountPercentage   Int       @default(0)
  discountEndDate      DateTime?
  expiryDate           DateTime?
  tags                 String[]  @default([])
  rating               Float     @default(0)
  reviewCount          Int       @default(0)
  orderCount           Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   PharmacyCategory? @relation(fields: [categoryId], references: [id])
  store      PharmacyStore    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([storeId])
  @@index([categoryId])
  @@map("pharmacy_items")
}

// ==================== ORDER ====================

model Order {
  id                 String           @id @default(cuid())
  orderNumber        String           @unique
  orderType          OrderType        @default(food)
  customerId         String
  restaurantId       String?
  groceryStoreId     String?
  pharmacyStoreId    String?
  riderId            String?
  subtotal           Float
  deliveryFee        Float            @default(0)
  tax                Float            @default(0)
  totalAmount        Float
  paymentMethod      PaymentMethod
  paymentProvider    PaymentProvider?
  paymentReferenceId String?
  paymentStatus      PaymentStatus    @default(pending)
  status             OrderStatus      @default(pending)
  orderDate          DateTime         @default(now())
  expectedDelivery   DateTime?
  deliveredDate      DateTime?
  cancelledDate      DateTime?
  cancellationReason String?
  promoCode          String?
  promoDiscount      Float            @default(0)
  promoType          PromoType?
  notes              String?

  // Rider Earnings Breakdown
  riderBaseFee      Float @default(5.0)   // Base delivery fee (GHS)
  riderDistanceFee  Float @default(0)     // Distance-based fee (calculated)
  riderTip          Float @default(0)     // Customer tip
  platformFee       Float @default(0)     // Platform commission
  riderEarnings     Float @default(0)     // Total rider gets (baseFee + distanceFee + tip - platformFee)

  // Delivery Address
  deliveryStreet    String
  deliveryCity      String
  deliveryState     String?
  deliveryZipCode   String?
  deliveryLatitude  Float?
  deliveryLongitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer      User           @relation("CustomerOrders", fields: [customerId], references: [id])
  rider         User?          @relation("RiderOrders", fields: [riderId], references: [id])
  restaurant    Restaurant?    @relation(fields: [restaurantId], references: [id])
  groceryStore  GroceryStore?  @relation("GroceryStoreOrders", fields: [groceryStoreId], references: [id])
  pharmacyStore PharmacyStore? @relation("PharmacyStoreOrders", fields: [pharmacyStoreId], references: [id])
  items         OrderItem[]
  payments      Payment[]

  @@index([customerId])
  @@index([restaurantId])
  @@index([riderId])
  @@index([status])
  @@index([orderDate])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  itemType       ItemType
  foodId         String?
  groceryItemId  String?
  pharmacyItemId String?
  name           String
  quantity       Int
  price          Float
  image          String?
  unit           String?

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  food         Food?         @relation(fields: [foodId], references: [id])
  groceryItem  GroceryItem?  @relation(fields: [groceryItemId], references: [id])
  pharmacyItem PharmacyItem? @relation(fields: [pharmacyItemId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ==================== CART ====================

model Cart {
  id                            String    @id @default(cuid())
  userId                        String
  cartType                      CartType
  restaurantId                  String?
  groceryStoreId                String?
  pharmacyStoreId               String?
  totalAmount                   Float     @default(0)
  itemCount                     Int       @default(0)
  lastUpdatedAt                 DateTime  @default(now())
  abandonmentNotificationSent   Boolean   @default(false)
  abandonmentNotificationSentAt DateTime?
  lastAbandonmentCheckAt        DateTime?
  isActive                      Boolean   @default(true)
  convertedToOrder              Boolean   @default(false)
  orderId                       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@index([cartType])
  @@map("carts")
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  itemType       ItemType
  foodId         String?
  groceryItemId  String?
  pharmacyItemId String?
  name           String
  price          Float
  quantity       Int      @default(1)
  imageUrl       String?
  addedAt        DateTime @default(now())

  cart         Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  food         Food?         @relation(fields: [foodId], references: [id])
  groceryItem  GroceryItem?  @relation(fields: [groceryItemId], references: [id])
  pharmacyItem PharmacyItem? @relation(fields: [pharmacyItemId], references: [id])

  @@index([cartId])
  @@map("cart_items")
}

// ==================== CHAT ====================



// ==================== PAYMENT ====================

model Payment {
  id                     String           @id @default(cuid())
  orderId                String
  customerId             String
  paymentMethod          PaymentMethod
  provider               PaymentProvider?
  amount                 Float
  currency               Currency         @default(GHS)
  status                 PaymentStatus    @default(pending)
  referenceId            String           @unique
  externalReferenceId    String?
  financialTransactionId String?
  phoneNumber            String?
  payerMessage           String?
  payeeNote              String?
  errorMessage           String?
  errorCode              String?
  metadata               Json?
  initiatedAt            DateTime         @default(now())
  completedAt            DateTime?
  expiredAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order    Order @relation(fields: [orderId], references: [id])
  customer User  @relation(fields: [customerId], references: [id])

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@map("payments")
}

// ==================== RIDER ====================

model Rider {
  id                     String               @id @default(cuid())
  userId                 String               @unique
  vehicleType            VehicleType?
  licensePlateNumber     String?
  vehicleBrand           String?
  vehicleModel           String?
  vehicleImage           String?
  nationalIdType         IdType?
  nationalIdNumber       String?
  idFrontImage           String?
  idBackImage            String?
  selfiePhoto            String?
  paymentMethod          String?
  bankName               String?
  accountNumber          String?
  accountHolderName      String?
  mobileMoneyProvider    MobileMoneyProvider?
  mobileMoneyNumber      String?
  verificationStatus     VerificationStatus   @default(pending)
  rejectionReason        String?
  verifiedAt             DateTime?
  agreedToTerms          Boolean              @default(false)
  agreedToLocationAccess Boolean              @default(false)
  agreedToAccuracy       Boolean              @default(false)
  notes                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("riders")
}

model RiderWallet {
  id                String @id @default(cuid())
  userId            String @unique
  balance           Float  @default(0)
  totalEarnings     Float  @default(0)
  totalWithdrawals  Float  @default(0)
  pendingWithdrawals Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("rider_wallets")
}

model Transaction {
  id          String  @id @default(cuid())
  walletId    String
  userId      String
  type        String // 'earning', 'withdrawal', 'bonus', 'penalty'
  amount      Float
  description String?
  referenceId String?
  status      String  @default("completed")

  createdAt DateTime @default(now())

  wallet RiderWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@map("transactions")
}

// ==================== STATUS (Stories) ====================



// ==================== NOTIFICATION ====================



model ScheduledNotification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  scheduledAt DateTime
  sent        Boolean   @default(false)
  sentAt      DateTime?
  data        Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@index([sent])
  @@map("scheduled_notifications")
}

// ==================== PROMO CODE ====================

model PromoCode {
  id                   String      @id @default(cuid())
  code                 String      @unique
  type                 PromoType
  value                Float
  description          String?
  isActive             Boolean     @default(true)
  startDate            DateTime    @default(now())
  endDate              DateTime?
  maxUses              Int?
  currentUses          Int         @default(0)
  maxUsesPerUser       Int         @default(1)
  minOrderAmount       Float       @default(0)
  maxDiscountAmount    Float?
  applicableOrderTypes OrderType[] @default([])
  firstOrderOnly       Boolean     @default(false)
  createdById          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy     User?                   @relation("PromoCodeCreator", fields: [createdById], references: [id])
  targetedUsers PromoCodeTargetedUser[]

  @@index([code])
  @@index([isActive])
  @@map("promo_codes")
}

model PromoCodeTargetedUser {
  id          String @id @default(cuid())
  promoCodeId String
  userId      String

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@map("promo_code_targeted_users")
}

// ==================== PROMOTIONAL BANNER ====================

enum BannerAudience {
  all
  new_users
  premium
  frequent
}

model PromotionalBanner {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  imageUrl        String
  discount        String?
  backgroundColor String   @default("#FFFFFF")
  targetUrl       String?
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  priority        Int      @default(0)
  targetAudience  BannerAudience @default(all)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([startDate, endDate])
  @@map("promotional_banners")
}

