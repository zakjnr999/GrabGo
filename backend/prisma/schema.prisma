// ==================== GRABMART (Separate store type) ====================

model GrabMartStore {
  id          String       @id @default(cuid())
  storeName   String
  logo        String
  description String?
  phone       String
  email       String       @unique
  password    String?
  status      EntityStatus @default(pending)
  rating      Float        @default(0)
  ratingCount Int          @default(0)
  isOpen      Boolean      @default(true)
  deliveryFee Float        @default(0)
  minOrder    Float        @default(0)

  // GrabMart Specific
  is24Hours          Boolean  @default(false)
  services           String[] @default([])
  productTypes       String[] @default([])
  acceptsCash        Boolean  @default(true)
  acceptsCard        Boolean  @default(true)
  acceptsMobileMoney Boolean  @default(true)
  bannerImages       String[] @default([])

  // Location
  longitude Float
  latitude  Float
  address   String
  city      String
  area      String
  
  // Socials
  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  websiteUrl   String?
  
  paymentMethods String[] @default([])

  // Verification & Priority
  isVerified            Boolean   @default(false)
  verifiedAt            DateTime?
  priorityScore         Float     @default(0)
  orderAcceptanceRate   Float     @default(100)
  orderCancellationRate Float     @default(0)
  featured              Boolean   @default(false)
  featuredUntil         DateTime?
  
  // Metadata & Features
  features              String[]  @default([])
  tags                  String[]  @default([])
  whatsappNumber        String?
  timezone              String    @default("Africa/Accra")
  utcOffset             Int       @default(0)
  
  // Stats
  totalOrders          Int       @default(0)
  totalCancelledOrders Int       @default(0)
  totalRevenue         Float     @default(0)
  monthlyRevenue       Float     @default(0)
  last30DaysRevenue    Float     @default(0) 
  averageOrderValue    Float     @default(0)
  monthlyOrders        Int       @default(0)
  
  // Operational & Legacy
  ratingSum            Float     @default(0)
  totalReviews         Int       @default(0)
  isAcceptingOrders    Boolean   @default(true)
  isGrabGoExclusive    Boolean   @default(false)
  isGrabGoExclusiveUntil DateTime?
  vendorType           String    @default("grabmart")
  isDeleted            Boolean   @default(false)
  lastOnlineAt         DateTime  @default(now())
  
  parentVendorId       String?
  parentVendor         GrabMartStore? @relation("GrabMartStoreHierarchy", fields: [parentVendorId], references: [id])
  subVendors           GrabMartStore[] @relation("GrabMartStoreHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories GrabMartCategory[]
  items      GrabMartItem[]

  @@index([status])
  @@map("grabmart_stores")
}

model GrabMartCategory {
  id          String  @id @default(cuid())
  name        String
  description String?
  emoji       String?
  image       String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  storeId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store GrabMartStore? @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items GrabMartItem[]

  @@index([storeId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("grabmart_categories")
}

model GrabMartItem {
  id                 String    @id @default(cuid())
  name               String
  description        String?
  image              String
  price              Float
  unit               String?
  categoryId         String?
  storeId            String
  brand              String?
  stock              Int       @default(0)
  isAvailable        Boolean   @default(true)
  discountPercentage Int       @default(0)
  discountEndDate    DateTime?
  tags               String[]  @default([])
  rating             Float     @default(0)
  reviewCount        Int       @default(0)
  orderCount         Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category GrabMartCategory? @relation(fields: [categoryId], references: [id])
  store    GrabMartStore    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  favoritedBy UserFavoriteGrabMartItem[]

  @@index([storeId])
  @@index([categoryId])
  @@map("grabmart_items")
}
